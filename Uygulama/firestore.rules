rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "erdemtuzel@gmail.com" && request.auth.token.email_verified == true);
    }

    // Agency validation
    function isValidAgency(data) {
      return data.keys().hasAll(['name', 'contact', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.contact is string &&
             data.createdAt is string;
    }

    // Code validation
    function isValidCode(data) {
      return data.keys().hasAll(['code', 'agencyId', 'expirationDate', 'status', 'createdAt']) &&
             data.code is string && data.code.size() >= 8 &&
             data.agencyId is string &&
             data.expirationDate is string &&
             data.status in ['active', 'used', 'expired'] &&
             data.createdAt is string;
    }

    match /agencies/{agencyId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidAgency(request.resource.data);
      allow delete: if isAdmin();
    }

    match /codes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidCode(request.resource.data);
      allow update: if isAuthenticated() && 
        (
          // Admin can update anything
          isAdmin() || 
          // Validation staff can mark as used
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedAt']) &&
            resource.data.status == 'active' &&
            request.resource.data.status == 'used' &&
            request.resource.data.usedAt is string
          )
        );
      allow delete: if isAdmin();
    }
  }
}
